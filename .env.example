# ==========================================================
# 🐘 POSTGRES 17 (container) — credenciais do banco
# ==========================================================
POSTGRES_USER=studfy
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=studfy

# ==========================================================
# ⚙️ API
# ==========================================================
# Porta exposta no host para a API (dentro do container é sempre 8080)
API_PORT=8080

# true = roda o AutoMigrate no boot (necessário na primeira vez com banco vazio).
# Depois que as tabelas existirem, pode setar false para ligar mais rápido.
AUTO_MIGRATE=true

# release | debug
GIN_MODE=release

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque-por-um-segredo-bem-grande-e-aleatorio

# URL do front-end (usada em CORS e nos links de e-mail)
FRONTEND_URL=http://localhost:3000

# ==========================================================
# ✉️ E-MAIL (Brevo) — usado para verificação/reset de senha
# ==========================================================
BREVO_API_KEY=
SENDER_EMAIL=nao-responder@seudominio.com

# ==========================================================
# ℹ️ NOTA: DATABASE_URL NÃO é definida aqui.
# O docker-compose monta a DATABASE_URL automaticamente apontando
# para o serviço "db" a partir de POSTGRES_USER/PASSWORD/DB acima.
# ==========================================================
